  "engines": {
    "node": ">=22.0.0 <23.0.0",
    "yarn": ">=1.22.22 <2.0.0"
  },
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "nx run-many -t dev --parallel=2",
    "dev:api": "nx dev agent-api",
    "dev:web": "nx dev web",
    "lint": "nx run-many -t lint",
    "test": "nx run-many -t test",
    "build": "nx run-many -t build",
    "typecheck": "nx run-many -t typecheck",
    "e2e": "nx e2e web",
    "benchmark:agents": "tsx --tsconfig apps/agent-api/tsconfig.json apps/agent-api/src/benchmark.ts"
  },
  "dependencies": {
    "@nestjs/common": "^11.1.6",
