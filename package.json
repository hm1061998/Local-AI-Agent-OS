  "devDependencies": {
    "@eslint/js": "^9.38.0",
    "@nx/eslint": "23.1.0",
    "@nx/js": "23.1.0",
    "@nx/vite": "23.1.0",
    "@nx/workspace": "23.1.0",
    "@playwright/test": "^1.56.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.5",
    "@types/node": "^24.9.1",
    "@types/react": "^19.2.2",
    "@types/react-dom": "^19.2.2",
    "@types/three": "0.180.0",
    "@vitejs/plugin-react": "^5.0.4",
    "eslint": "^9.38.0",
