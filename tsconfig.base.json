{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "baseUrl": ".",
    "paths": {
      "@local-agent/agent-protocol": ["packages/agent-protocol/src/index.ts"],
      "@local-agent/event-schema": ["packages/event-schema/src/index.ts"],
      "@local-agent/model-provider": ["packages/model-provider/src/index.ts"],
      "@local-agent/skill-schema": ["packages/skill-schema/src/index.ts"],
      "@local-agent/shared-types": ["packages/shared-types/src/index.ts"],
      "@local-agent/test-utils": ["packages/test-utils/src/index.ts"]
    }
  }
}
